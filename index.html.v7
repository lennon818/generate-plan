<!DOCTYPE html>
<html>
<head>

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&family=Permanent+Marker&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Space Grotesk', sans-serif;
  background: #e9eceb;
}

/* branding */
.branding {
  position: fixed;
  top: 30px;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  background: #f4e7c5;
  padding: 10px 30px;
  font-family: 'Permanent Marker', cursive;
  font-size: 18px;
  box-shadow: 0 6px 12px rgba(0,0,0,0.2);
}

/* layout */
.scene {
  display: flex;
  flex-wrap: wrap;
  gap: 40px;
  justify-content: center;
  padding: 100px 40px 40px;
}

/* polaroid */
.polaroid {
  width: 260px;
  height: 320px;
  background: white;
  padding: 12px 12px 50px 12px;
  box-shadow: 0 25px 50px rgba(0,0,0,0.25);
}

/* photo */
.photo {
  width: 100%;
  height: 220px;
  background: black;
  padding: 12px;
  color: white;
  font-size: 16px;
  overflow: auto;
}

/* textarea */
textarea {
  width: 100%;
  height: 100%;
  background: transparent;
  border: none;
  color: white;
  font-family: 'Space Grotesk';
  font-size: 16px;
}

/* label */
.label {
  font-family: 'Permanent Marker', cursive;
  text-align: center;
  margin-top: 10px;
}

/* button */
.generate-container {
  text-align: center;
  margin: 40px;
}

.generate-action {
  display: inline-block;
  background: white;
  padding: 10px 20px;
  border: 1px solid black;
  font-family: 'Permanent Marker', cursive;
  cursor: pointer;
}
</style>

</head>

<body>

<div class="branding">PAYAM EMRANI</div>

<div class="scene">

  <div class="polaroid">
    <div class="photo">
      <textarea placeholder="Enter notes..."></textarea>
    </div>
    <div class="label">NOTES</div>
  </div>

  <div class="polaroid"><div class="photo" id="overview"></div><div class="label">OVERVIEW</div></div>
  <div class="polaroid"><div class="photo" id="tasks"></div><div class="label">TASKS</div></div>
  <div class="polaroid"><div class="photo" id="equipment"></div><div class="label">EQUIPMENT</div></div>
  <div class="polaroid"><div class="photo" id="timeline"></div><div class="label">TIMELINE</div></div>
  <div class="polaroid"><div class="photo" id="contacts"></div><div class="label">CONTACTS</div></div>
  <div class="polaroid"><div class="photo" id="keywords"></div><div class="label">KEYWORDS</div></div>

</div>

<div class="generate-container">
  <div class="generate-action" id="generateBtn">
    GENERATE PLAN
  </div>
</div>

<script>
function extractContacts(text) {
  const lines = text.split("\n");
  const contacts = [];

  lines.forEach(line => {

    const emailMatch = line.match(
      /([A-Z][a-z]+)[^\n]*?([a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.[a-z]{2,})/
    );

    const phoneMatch = line.match(
      /([A-Z][a-z]+)[^\n]*?(\b\d{3}[-.\s]?\d{3}[-.\s]?\d{4}\b)/
    );

    if (emailMatch) {
      contacts.push(`${emailMatch[1]} – ${emailMatch[2]}`);
    } else if (phoneMatch) {
      contacts.push(`${phoneMatch[1]} – ${phoneMatch[2]}`);
    }

  });

  return contacts;
}

window.onload = function () {

  document.getElementById("generateBtn").onclick = function () {

    const notes = document.querySelector("textarea").value;

    const contacts = extractContacts(notes);

    document.getElementById("overview").innerHTML =
      "1. Shoot concept defined<br>2. Creative direction aligned";

    document.getElementById("tasks").innerHTML =
      "1. Prep gear<br>2. Confirm location<br>3. Shoot";

    document.getElementById("equipment").innerHTML =
      "1. Camera<br>2. Lighting<br>3. Tripod";

    document.getElementById("timeline").innerHTML =
      "1. Setup<br>2. Shoot<br>3. Wrap";

    document.getElementById("contacts").innerHTML =
      contacts.length
        ? contacts.map((c, i) => `${i + 1}. ${c}`).join("<br>")
        : "No contacts found";

    document.getElementById("keywords").innerHTML =
      "1. Editorial<br>2. Moody<br>3. Soft Light";

  };

};
</script>

</body>
</html>