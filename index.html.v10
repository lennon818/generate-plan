<!DOCTYPE html>
<html>
<head>

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&family=Permanent+Marker&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Space Grotesk', sans-serif;
  background: url('https://www.transparenttextures.com/patterns/wood.png');
  background-color: #7a5a3a;
}

/* CONTAINER */
#output {
  position: relative;
  min-height: 900px;
  padding: 40px;
}

/* POLAROID */
.polaroid {
  width: 260px;
  background: white;
  padding: 15px 15px 40px 15px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  position: absolute;
}

/* TAPE */
.tape {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  background: #f5e6a1;
  padding: 5px 20px;
  font-size: 12px;
  font-weight: bold;
  color: #000;
}

/* CONTENT */
.content {
  font-size: 14px;
  color: #111;
}

.item {
  margin-bottom: 6px;
}
</style>

</head>

<body>

<div id="output"></div>

<script>
// ===== EXACT LAYOUT =====
const layoutMap = {
  notes:      { top: "40px",  left: "60px",  rotate: "-3deg" },
  moodboard:  { top: "40px",  left: "360px", rotate: "2deg" },

  sticker:    { top: "220px", left: "220px", rotate: "-1deg" },

  contacts:   { top: "420px", left: "60px",  rotate: "3deg" },
  skills:     { top: "420px", left: "260px", rotate: "-2deg" },
  equipment:  { top: "420px", left: "460px", rotate: "2deg" },

  experience: { top: "620px", left: "260px", rotate: "-1deg" }
};

// ===== FORMAT =====
function formatItem(item) {
  if (typeof item === "string") return item;
  return `${item.name || ""} ${item.email || ""} ${item.phone || ""}`.trim();
}

// ===== CREATE POLAROID (keeps titles simple) =====
function createPolaroid(section, items) {
  const div = document.createElement("div");
  div.className = "polaroid";

  div.innerHTML = `
    <div class="tape">${section}</div>
    <div class="content">
      ${(items || []).map(i => `<div class="item">${formatItem(i)}</div>`).join("")}
    </div>
  `;

  return div;
}

// ===== RENDER =====
function renderPolaroids(data) {
  const container = document.getElementById("output");
  container.innerHTML = "";

  const sections = [
    "notes",
    "moodboard",
    "sticker",
    "contacts",
    "skills",
    "equipment",
    "experience"
  ];

  sections.forEach(section => {
    const card = createPolaroid(section, data[section] || []);
    const pos = layoutMap[section];

    if (pos) {
      card.style.top = pos.top;
      card.style.left = pos.left;
      card.style.transform = `rotate(${pos.rotate})`;
    }

    container.appendChild(card);
  });
}

// ===== SAMPLE DATA (replace with yours) =====
const data = {
  notes: ["Lighting notes", "Keep it minimal"],
  moodboard: ["Black & white", "Soft shadows"],
  sticker: ["Generate concept"],
  contacts: [{ name: "John Smith", email: "john@email.com" }],
  skills: ["Sony", "Capture One"],
  equipment: ["Godox lights"],
  experience: ["Studio assistant"]
};

// ===== INIT =====
renderPolaroids(data);
</script>

</body>
</html>