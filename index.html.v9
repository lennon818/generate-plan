<!DOCTYPE html>
<html>
<head>

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700&family=Permanent+Marker&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Space Grotesk', sans-serif;
  background: #e9eceb;
}

.branding {
  position: fixed;
  top: 30px;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  background: #f4e7c5;
  padding: 10px 30px;
  font-family: 'Permanent Marker', cursive;
  font-size: 18px;
  box-shadow: 0 6px 12px rgba(0,0,0,0.2);
  z-index: 1000;
}

.polaroid {
  width: 260px;
  height: 320px;
  background: white;
  padding: 12px 12px 50px 12px;
  box-shadow: 0 25px 50px rgba(0,0,0,0.25);
  position: absolute;
}

.photo {
  width: 100%;
  height: 220px;
  background: black;
  padding: 12px;
  color: white;
  font-size: 16px;
  overflow: auto;
}

textarea {
  width: 100%;
  height: 100%;
  background: transparent;
  border: none;
  color: white;
  font-family: 'Space Grotesk';
  font-size: 16px;
}

.label {
  font-family: 'Permanent Marker', cursive;
  text-align: center;
  margin-top: 10px;
}

.generate-container {
  position: fixed;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
}

.generate-action {
  display: inline-block;
  background: white;
  padding: 10px 20px;
  border: 1px solid black;
  font-family: 'Permanent Marker', cursive;
  cursor: pointer;
}
</style>

</head>

<body>

<div class="branding">PAYAM EMRANI</div>

<div id="output" style="position: relative; min-height: 900px; width: 100%;"></div>

<div class="generate-container">
  <div class="generate-action" id="generateBtn">
    GENERATE PLAN
  </div>
</div>

<script>
// ===== LAYOUT (your exact positions) =====
const layoutMap = {
  notes:      { top: "40px",  left: "60px",  rotate: "-3deg" },
  moodboard:  { top: "40px",  left: "360px", rotate: "2deg" },

  sticker:    { top: "220px", left: "220px", rotate: "-1deg" },

  contacts:   { top: "420px", left: "60px",  rotate: "3deg" },
  skills:     { top: "420px", left: "260px", rotate: "-2deg" },
  equipment:  { top: "420px", left: "460px", rotate: "2deg" },

  experience: { top: "620px", left: "260px", rotate: "-1deg" }
};

// ===== ENSURE CONTAINER SUPPORTS POSITIONING =====
const container = document.getElementById("output");
if (container) {
  container.style.position = "relative";
  container.style.minHeight = "900px";
}

// ===== RENDER (PLACEMENT-CONTROLLED) =====
function renderPolaroids(data) {
  const container = document.getElementById("output");
  container.innerHTML = "";

  const sections = [
    "notes",
    "moodboard",
    "sticker",
    "contacts",
    "skills",
    "equipment",
    "experience"
  ];

  sections.forEach(section => {
    const card = createPolaroid(section, data[section] || []);

    const pos = layoutMap[section];
    if (pos) {
      card.style.position = "absolute";
      card.style.top = pos.top;
      card.style.left = pos.left;
      card.style.transform = `rotate(${pos.rotate})`;
    }

    container.appendChild(card);
  });
}

function extractContacts(text) {
  const lines = text.split("\n");
  const contacts = [];

  lines.forEach(line => {
    const emailMatch = line.match(/[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.[a-z]{2,}/);
    const phoneMatch = line.match(/\b\d{3}[-.\s]?\d{3}[-.\s]?\d{4}\b/);
    const contact = emailMatch ? emailMatch[0] : phoneMatch ? phoneMatch[0] : null;

    if (contact) {
      const index = line.indexOf(contact);
      const before = line.slice(0, index).trim();
      const words = before.split(/\s+/);
      let name = "Unknown";
      for (let i = words.length - 1; i >= 0; i--) {
        if (/^[A-Z][a-z]+$/.test(words[i])) {
          name = words[i];
          break;
        }
      }
      contacts.push(`${name} - ${contact}`);
    }
  });

  return contacts;
}

function createPolaroid(id, content) {
  const div = document.createElement("div");
  div.className = "polaroid";
  div.id = id;
  
  const photo = document.createElement("div");
  photo.className = "photo";
  if (id === "notes") {
    photo.innerHTML = `<textarea id="notesInput" placeholder="Enter notes..."></textarea>`;
  } else {
    photo.textContent = Array.isArray(content) ? content.join(", ") : content;
  }
  
  const label = document.createElement("div");
  label.className = "label";
  label.textContent = id.toUpperCase();
  
  div.appendChild(photo);
  div.appendChild(label);
  return div;
}

window.onload = function () {
  document.getElementById("generateBtn").onclick = function () {
    const notes = document.getElementById("notesInput").value;
    const contacts = extractContacts(notes);

    const data = {
      notes: notes,
      moodboard: "",
      sticker: "STICKER",
      contacts: contacts,
      skills: "1. Photography\n2. Lighting\n3. Editing",
      equipment: "1. Camera\n2. Lens\n3. Tripod",
      experience: "1. Shoot concept defined"
    };

    renderPolaroids(data);
  };
};
</script>

</body>
</html>